{
    "commit-msg": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\Message\\Action\\Regex",
                "options": {
                    "regex": "#^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|ops|revert)(\\(.+\\))?(!)?: .+#",
                    "error": "Commit message doesn't follow the Conventional Commits format.\n  Expected : type(scope)?: description\n  Valid types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, ops, revert\n  Examples  : feat: add gallery view\n              fix(books): correct rating display\n  Got       : %s"
                }
            }
        ]
    },
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "php artisan translations:prune"
            },
            {
                "action": "git add lang/fr.json"
            }
        ]
    },
    "pre-push": {
        "enabled": true,
        "actions": [
            {
                "action": "vendor/bin/pint --test"
            },
            {
                "action": "vendor/bin/phpstan analyse --no-progress --memory-limit=512M"
            },
            {
                "action": "php artisan test --compact"
            }
        ]
    }
}
